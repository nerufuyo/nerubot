# ============================================================
# NeruBot (Discord Bot) — Environment Configuration
# ============================================================
# Copy to .env and fill in values.
# DO NOT commit real secrets to version control.
# ============================================================

# ── SHARED VARIABLES (Railway Shared Variables) ──────────────
# These are used by: API, MBG Scrapper, NeruBot

# MongoDB (required)
MONGO_URL=mongodb://user:password@host:port
MONGO_DB=nerufuyo

# DeepSeek LLM
DEEPSEEK_API_KEY=your_deepseek_api_key

# Ollama (LLM fallback)
OLLAMA_URL=

# ── BOT-ONLY VARIABLES ──────────────────────────────────────

# Discord (required)
DISCORD_TOKEN=your_discord_bot_token

# Redis (optional — enables persistent chat sessions & music queue state)
REDIS_URL=redis://default:password@host:port

# Backend API (RAG knowledge & bot settings from dashboard)
BACKEND_URL=

# --- Features (true/false) ---
ENABLE_CONFESSION=true
ENABLE_ROAST=true
ENABLE_REMINDER=true

# --- Whale Alert (optional) ---
WHALE_ALERT_API_KEY=

# --- Reminder Channel (optional) ---
# Discord channel ID for reminders. Leave blank — users can set it with /reminder-set.
REMINDER_CHANNEL_ID=

# --- Music (Lavalink) ---
ENABLE_MUSIC=false
LAVALINK_ADDRESS=localhost:2333
LAVALINK_PASSWORD=youshallnotpass
YOUTUBE_OAUTH_ENABLED=false
YOUTUBE_OAUTH_REFRESH_TOKEN=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Runtime ---
LOG_LEVEL=INFO
ENVIRONMENT=development
